# Copy this file to .env and fill in real values. Never commit .env.

# Postgres connection string used by Prisma (see Phase 2). Matches docker-compose.yml defaults for local dev.
DATABASE_URL="postgresql://crm:crm_dev_password@localhost:5432/crm?schema=public"

# Session cookie signing secret (Phase 3). Generate a long random string per environment.
SESSION_SECRET="replace-with-a-long-random-string"

# Per-tenant webhook HMAC signing is stored in the database (Phase 7), not here.
