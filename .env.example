# Copy this file to .env and fill in real values. Never commit .env.

# Postgres connection string used by Prisma (see Phase 2). Matches docker-compose.yml defaults for local dev.
DATABASE_URL="postgresql://crm:crm_dev_password@localhost:5432/crm?schema=public"

# Session token pepper (Phase 3) — the server refuses to start auth routes without a real value here.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET="replace-with-a-long-random-string"

# Per-tenant webhook HMAC signing secrets are stored in the database (Phase 7), not here.

# Shared secret for the external scheduler that triggers webhook retry processing
# (see EVENTS.md). Generate the same way as SESSION_SECRET.
WEBHOOK_PROCESSOR_SECRET="replace-with-a-long-random-string"

# Optional — both default to their v1-only implementation if unset. Real
# Google/Outlook calendars (Phase 15) and a real contact-enrichment service
# aren't implemented yet; setting either to anything but the default throws
# a clear error rather than silently doing nothing.
# CALENDAR_PROVIDER="mock"
# ENRICHMENT_PROVIDER="noop"
