// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MEMBER
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  plan      String   @default("trial")
  createdAt DateTime @default(now()) @map("created_at")

  users             User[]
  accounts          Account[]
  contacts          Contact[]
  leads             Lead[]
  opportunities     Opportunity[]
  activities        Activity[]
  forms             Form[]
  formSubmissions   FormSubmission[]
  webhookEndpoints  WebhookEndpoint[]
  webhookDeliveries WebhookDelivery[]
  apiKeys           ApiKey[]
  callBookings      CallBooking[]
  pipelineStages    PipelineStage[]
  invoices          Invoice[]
  calendarConnection CalendarConnection?
  customFieldDefinitions CustomFieldDefinition[]
  customFieldValues      CustomFieldValue[]
  tags                   Tag[]
  tagAssignments         TagAssignment[]
  notes                  Note[]
  emailLogs              EmailLog[]
  attachments            Attachment[]
  tasks                  Task[]
  products               Product[]
  quotes                 Quote[]
  quoteLines             QuoteLine[]

  @@map("tenants")
}

model Account {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  name        String
  ownerUserId String?  @map("owner_user_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner         User?         @relation("AccountOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  contacts      Contact[]
  opportunities Opportunity[]

  @@index([tenantId])
  @@map("accounts")
}

model User {
  id                  String    @id @default(cuid())
  tenantId            String    @map("tenant_id")
  email               String    @unique
  passwordHash        String    @map("password_hash")
  role                Role      @default(MEMBER)
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until")
  createdAt           DateTime  @default(now()) @map("created_at")

  tenant             Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions           Session[]
  ownedLeads         Lead[]        @relation("LeadOwner")
  ownedOpportunities Opportunity[] @relation("OpportunityOwner")
  ownedContacts      Contact[]     @relation("ContactOwner")
  ownedAccounts      Account[]     @relation("AccountOwner")
  notes              Note[]
  tasks              Task[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Contact {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  accountId   String?  @map("account_id")
  ownerUserId String?  @map("owner_user_id")
  firstName   String   @map("first_name")
  lastName    String?  @map("last_name")
  email       String?
  phone       String?
  company     String?
  dedupeKey   String?  @map("dedupe_key")
  createdAt   DateTime @default(now()) @map("created_at")

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  account       Account?      @relation(fields: [accountId], references: [id], onDelete: SetNull)
  owner         User?         @relation("ContactOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  leads         Lead[]
  opportunities Opportunity[]
  emailLogs     EmailLog[]

  @@index([tenantId])
  @@index([tenantId, dedupeKey])
  @@map("contacts")
}

model Lead {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  contactId   String   @map("contact_id")
  source      String   @default("manual")
  status      String   @default("new")
  ownerUserId String?  @map("owner_user_id")
  score       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact         Contact          @relation(fields: [contactId], references: [id], onDelete: Cascade)
  owner           User?            @relation("LeadOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  opportunities   Opportunity[]
  formSubmissions FormSubmission[]
  callBookings    CallBooking[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("leads")
}

model Opportunity {
  id                String    @id @default(cuid())
  tenantId          String    @map("tenant_id")
  contactId         String    @map("contact_id")
  accountId         String?   @map("account_id")
  leadId            String?   @map("lead_id")
  name              String
  stage             String    @default("new")
  value             Decimal   @default(0) @db.Decimal(12, 2)
  currency          String    @default("USD")
  probability       Int       @default(0)
  ownerUserId       String?   @map("owner_user_id")
  expectedCloseDate DateTime? @map("expected_close_date")
  closedAt          DateTime? @map("closed_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact  Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  account  Account?  @relation(fields: [accountId], references: [id], onDelete: SetNull)
  lead     Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  owner    User?     @relation("OpportunityOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  invoices Invoice[]
  quotes   Quote[]

  @@index([tenantId])
  @@index([tenantId, stage])
  @@map("opportunities")
}

model Activity {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  type       String
  payload    Json?
  createdAt  DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, entityType, entityId])
  @@map("activities")
}

model Form {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  name      String
  fields    Json
  embedKey  String   @unique @map("embed_key")
  createdAt DateTime @default(now()) @map("created_at")

  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  submissions FormSubmission[]

  @@index([tenantId])
  @@map("forms")
}

model FormSubmission {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  formId    String   @map("form_id")
  payload   Json
  status    String   @default("accepted")
  leadId    String?  @map("lead_id")
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  form   Form   @relation(fields: [formId], references: [id], onDelete: Cascade)
  lead   Lead?  @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([formId])
  @@index([formId, ipAddress, createdAt])
  @@map("form_submissions")
}

model WebhookEndpoint {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  url       String
  secret    String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  tenant     Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([tenantId])
  @@map("webhook_endpoints")
}

model WebhookDelivery {
  id                 String    @id @default(cuid())
  tenantId           String    @map("tenant_id")
  webhookEndpointId  String    @map("webhook_endpoint_id")
  eventId            String    @map("event_id")
  eventType          String    @map("event_type")
  payload            Json
  status             String    @default("pending")
  attempts           Int       @default(0)
  nextAttemptAt      DateTime  @map("next_attempt_at")
  lastAttemptAt      DateTime? @map("last_attempt_at")
  lastError          String?   @map("last_error")
  lastResponseStatus Int?      @map("last_response_status")
  createdAt          DateTime  @default(now()) @map("created_at")

  tenant   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  endpoint WebhookEndpoint @relation(fields: [webhookEndpointId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status, nextAttemptAt])
  @@map("webhook_deliveries")
}

model ApiKey {
  id         String    @id @default(cuid())
  tenantId   String    @map("tenant_id")
  name       String
  keyHash    String    @unique @map("key_hash")
  keyPrefix  String    @map("key_prefix")
  createdAt  DateTime  @default(now()) @map("created_at")
  lastUsedAt DateTime? @map("last_used_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("api_keys")
}

model CallBooking {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  leadId          String?  @map("lead_id")
  provider        String   @default("mock")
  externalEventId String   @map("external_event_id")
  startsAt        DateTime @map("starts_at")
  endsAt          DateTime @map("ends_at")
  attendeeEmail   String   @map("attendee_email")
  status          String   @default("confirmed")
  createdAt       DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead   Lead?  @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@map("call_bookings")
}

// Defines the configurable Kanban columns for a tenant's opportunity pipeline.
// Opportunity.stage stays a plain string (matching PipelineStage.key) rather
// than a foreign key, so the Phase 8 API contract (stage as a string) never
// has to change.
model PipelineStage {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  key       String
  label     String
  sortOrder Int      @map("sort_order")
  isWon     Boolean  @default(false) @map("is_won")
  isLost    Boolean  @default(false) @map("is_lost")
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@index([tenantId])
  @@map("pipeline_stages")
}

// Placeholder record for the Finance Agent n8n flow — a real accounting-tool
// integration (Xero/QuickBooks/Stripe) is a non-goal for v1 per PLAN.md;
// externalRef is where that tool's own invoice ID would go once wired up.
model Invoice {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  opportunityId String   @map("opportunity_id")
  amount        Decimal  @db.Decimal(12, 2)
  currency      String   @default("USD")
  status        String   @default("draft")
  externalRef   String?  @map("external_ref")
  createdAt     DateTime @default(now()) @map("created_at")

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([opportunityId])
  @@map("invoices")
}

// Generic IP-based rate limiter backing (login, signup, and other public
// endpoints) — a plain Postgres table rather than Redis, consistent with the
// "one less service to run" decision from PLAN.md's Phase 0 tech-stack pick.
model RateLimitHit {
  id        String   @id @default(cuid())
  key       String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([key, createdAt])
  @@map("rate_limit_hits")
}

// Records security-sensitive actions (auth events, API key/webhook endpoint
// changes) independently of the per-entity Activity timeline, which only
// tracks business-record changes (leads/opportunities/etc).
model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String?  @map("tenant_id")
  actorUserId String?  @map("actor_user_id")
  action      String
  metadata    Json?
  ipAddress   String?  @map("ip_address")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@map("audit_logs")
}

// One connected real-calendar account per tenant (the tenant's own OAuth
// grant — this is not per-user, since call-booking acts on behalf of the
// business, not an individual rep). Access/refresh tokens are opaque
// third-party secrets, same trust boundary as passwordHash: never returned
// in any API response.
model CalendarConnection {
  id           String   @id @default(cuid())
  tenantId     String   @unique @map("tenant_id")
  provider     String
  accountEmail String   @map("account_email")
  accessToken  String   @map("access_token")
  refreshToken String   @map("refresh_token")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("calendar_connections")
}

// Tenant-defined extra fields on Contact/Account/Opportunity, so a business
// can adapt the CRM to its own data without a code change. entityType is a
// plain string ("contact"/"account"/"opportunity") rather than a relation —
// mirrors the existing Activity.entityType/entityId pattern (Phase 4) rather
// than inventing a new polymorphic-relation convention.
model CustomFieldDefinition {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  entityType String  @map("entity_type")
  key       String
  label     String
  type      String // "text" | "number" | "date" | "select"
  options   Json? // for type "select": string[]
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  values CustomFieldValue[]

  @@unique([tenantId, entityType, key])
  @@index([tenantId, entityType])
  @@map("custom_field_definitions")
}

model CustomFieldValue {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  definitionId String   @map("definition_id")
  entityId     String   @map("entity_id")
  value        String?
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant     Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  definition CustomFieldDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)

  @@unique([definitionId, entityId])
  @@index([tenantId, entityId])
  @@map("custom_field_values")
}

// Per-tenant tag catalog + many-to-many assignments. entityType is a plain
// string ("contact"/"account"/"lead"/"opportunity"), same polymorphic
// convention as Activity/CustomFieldDefinition, so tagging any future entity
// type is additive.
model Tag {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  name      String
  color     String   @default("zinc")
  createdAt DateTime @default(now()) @map("created_at")

  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignments TagAssignment[]

  @@unique([tenantId, name])
  @@map("tags")
}

model TagAssignment {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  tagId      String   @map("tag_id")
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  createdAt  DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([tagId, entityId])
  @@index([tenantId, entityType, entityId])
  @@map("tag_assignments")
}

// Freeform, timestamped notes on a record — merged with Activity into the
// unified per-record timeline (Phase 21). Same polymorphic entityType/
// entityId convention as Activity/CustomFieldDefinition/TagAssignment.
// authorUserId is SetNull (not Cascade) on user deletion, same reasoning as
// AuditLog: a note's content should survive the author leaving the tenant.
model Note {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  entityType   String   @map("entity_type")
  entityId     String   @map("entity_id")
  authorUserId String?  @map("author_user_id")
  body         String
  createdAt    DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  author User?  @relation(fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, entityType, entityId])
  @@map("notes")
}

// Manual email logging on a Contact (Phase 22) — a "Log an email" action,
// not a real inbox sync (explicit v1 non-goal, see PLAN.md §7). Deliberately
// the same shape a real IMAP/Gmail/Graph sync would populate later, so that
// feature (if ever built) can write into this same table without a schema
// change — the manual action and a future sync are the same data source
// from the timeline's point of view.
model EmailLog {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  contactId  String   @map("contact_id")
  direction  String // "inbound" | "outbound"
  subject    String
  body       String
  occurredAt DateTime @map("occurred_at")
  createdAt  DateTime @default(now()) @map("created_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([tenantId, contactId])
  @@map("email_logs")
}

// File attachments on any record (Phase 23), stored via a StorageProvider
// (local disk in dev, same swap-later pattern as CalendarProvider — an Azure
// Blob provider is a config change, not a rewrite). storageKey is opaque to
// callers; only the provider that wrote it knows how to read it back.
model Attachment {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  entityType     String   @map("entity_type")
  entityId       String   @map("entity_id")
  fileName       String   @map("file_name")
  contentType    String   @map("content_type")
  sizeBytes      Int      @map("size_bytes")
  storageKey     String   @map("storage_key")
  uploadedByUserId String? @map("uploaded_by_user_id")
  createdAt      DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, entityType, entityId])
  @@map("attachments")
}

// Tasks/to-dos (Phase 24) — optionally linked to a record (entityType/
// entityId, nullable so a task can be standalone), always owned by exactly
// one user. "My tasks" is just this table filtered to ownerUserId = caller.
model Task {
  id          String    @id @default(cuid())
  tenantId    String    @map("tenant_id")
  title       String
  dueDate     DateTime? @map("due_date")
  ownerUserId String    @map("owner_user_id")
  entityType  String?   @map("entity_type")
  entityId    String?   @map("entity_id")
  status      String    @default("open") // "open" | "done"
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner  User   @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([tenantId, ownerUserId, status])
  @@index([tenantId, entityType, entityId])
  @@map("tasks")
}

// Minimal per-tenant product catalog (Phase 26) — feeds Quote line items
// (Phase 27). Deliberately no inventory/variants/tax rules; just enough to
// price a line item consistently instead of free-typing it every time.
model Product {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  name      String
  sku       String?
  unitPrice Decimal  @db.Decimal(12, 2) @map("unit_price")
  currency  String   @default("USD")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  quoteLines QuoteLine[]

  @@index([tenantId])
  @@map("products")
}

// A quote tied to an Opportunity (Phase 27). Totals are always computed
// from QuoteLine rows at read time (src/lib/quotes.ts), never cached on the
// Quote itself — avoids the total silently drifting out of sync with its
// lines.
model Quote {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  opportunityId String   @map("opportunity_id")
  status        String   @default("draft") // "draft" | "sent" | "accepted" | "declined"
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  lines       QuoteLine[]

  @@index([tenantId, opportunityId])
  @@map("quotes")
}

model QuoteLine {
  id          String  @id @default(cuid())
  tenantId    String  @map("tenant_id")
  quoteId     String  @map("quote_id")
  productId   String? @map("product_id")
  description String
  quantity    Decimal @default(1) @db.Decimal(10, 2)
  unitPrice   Decimal @db.Decimal(12, 2) @map("unit_price")
  sortOrder   Int     @default(0) @map("sort_order")

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  quote   Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([tenantId, quoteId])
  @@map("quote_lines")
}
