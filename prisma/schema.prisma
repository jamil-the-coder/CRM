// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MEMBER
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  plan      String   @default("trial")
  createdAt DateTime @default(now()) @map("created_at")

  users             User[]
  contacts          Contact[]
  leads             Lead[]
  opportunities     Opportunity[]
  activities        Activity[]
  forms             Form[]
  formSubmissions   FormSubmission[]
  webhookEndpoints  WebhookEndpoint[]
  webhookDeliveries WebhookDelivery[]
  apiKeys           ApiKey[]
  callBookings      CallBooking[]
  pipelineStages    PipelineStage[]
  invoices          Invoice[]

  @@map("tenants")
}

model User {
  id                  String    @id @default(cuid())
  tenantId            String    @map("tenant_id")
  email               String    @unique
  passwordHash        String    @map("password_hash")
  role                Role      @default(MEMBER)
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until")
  createdAt           DateTime  @default(now()) @map("created_at")

  tenant             Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions           Session[]
  ownedLeads         Lead[]        @relation("LeadOwner")
  ownedOpportunities Opportunity[] @relation("OpportunityOwner")

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Contact {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  firstName String   @map("first_name")
  lastName  String?  @map("last_name")
  email     String?
  phone     String?
  company   String?
  dedupeKey String?  @map("dedupe_key")
  createdAt DateTime @default(now()) @map("created_at")

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leads         Lead[]
  opportunities Opportunity[]

  @@index([tenantId])
  @@index([tenantId, dedupeKey])
  @@map("contacts")
}

model Lead {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  contactId   String   @map("contact_id")
  source      String   @default("manual")
  status      String   @default("new")
  ownerUserId String?  @map("owner_user_id")
  score       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact         Contact          @relation(fields: [contactId], references: [id], onDelete: Cascade)
  owner           User?            @relation("LeadOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  opportunities   Opportunity[]
  formSubmissions FormSubmission[]
  callBookings    CallBooking[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("leads")
}

model Opportunity {
  id                String    @id @default(cuid())
  tenantId          String    @map("tenant_id")
  contactId         String    @map("contact_id")
  leadId            String?   @map("lead_id")
  name              String
  stage             String    @default("new")
  value             Decimal   @default(0) @db.Decimal(12, 2)
  currency          String    @default("USD")
  probability       Int       @default(0)
  ownerUserId       String?   @map("owner_user_id")
  expectedCloseDate DateTime? @map("expected_close_date")
  closedAt          DateTime? @map("closed_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact  Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  lead     Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  owner    User?     @relation("OpportunityOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  invoices Invoice[]

  @@index([tenantId])
  @@index([tenantId, stage])
  @@map("opportunities")
}

model Activity {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  type       String
  payload    Json?
  createdAt  DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, entityType, entityId])
  @@map("activities")
}

model Form {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  name      String
  fields    Json
  embedKey  String   @unique @map("embed_key")
  createdAt DateTime @default(now()) @map("created_at")

  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  submissions FormSubmission[]

  @@index([tenantId])
  @@map("forms")
}

model FormSubmission {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  formId    String   @map("form_id")
  payload   Json
  status    String   @default("accepted")
  leadId    String?  @map("lead_id")
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  form   Form   @relation(fields: [formId], references: [id], onDelete: Cascade)
  lead   Lead?  @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([formId])
  @@index([formId, ipAddress, createdAt])
  @@map("form_submissions")
}

model WebhookEndpoint {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  url       String
  secret    String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  tenant     Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([tenantId])
  @@map("webhook_endpoints")
}

model WebhookDelivery {
  id                 String    @id @default(cuid())
  tenantId           String    @map("tenant_id")
  webhookEndpointId  String    @map("webhook_endpoint_id")
  eventId            String    @map("event_id")
  eventType          String    @map("event_type")
  payload            Json
  status             String    @default("pending")
  attempts           Int       @default(0)
  nextAttemptAt      DateTime  @map("next_attempt_at")
  lastAttemptAt      DateTime? @map("last_attempt_at")
  lastError          String?   @map("last_error")
  lastResponseStatus Int?      @map("last_response_status")
  createdAt          DateTime  @default(now()) @map("created_at")

  tenant   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  endpoint WebhookEndpoint @relation(fields: [webhookEndpointId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status, nextAttemptAt])
  @@map("webhook_deliveries")
}

model ApiKey {
  id         String    @id @default(cuid())
  tenantId   String    @map("tenant_id")
  name       String
  keyHash    String    @unique @map("key_hash")
  keyPrefix  String    @map("key_prefix")
  createdAt  DateTime  @default(now()) @map("created_at")
  lastUsedAt DateTime? @map("last_used_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("api_keys")
}

model CallBooking {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  leadId          String?  @map("lead_id")
  provider        String   @default("mock")
  externalEventId String   @map("external_event_id")
  startsAt        DateTime @map("starts_at")
  endsAt          DateTime @map("ends_at")
  attendeeEmail   String   @map("attendee_email")
  status          String   @default("confirmed")
  createdAt       DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead   Lead?  @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@map("call_bookings")
}

// Defines the configurable Kanban columns for a tenant's opportunity pipeline.
// Opportunity.stage stays a plain string (matching PipelineStage.key) rather
// than a foreign key, so the Phase 8 API contract (stage as a string) never
// has to change.
model PipelineStage {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  key       String
  label     String
  sortOrder Int      @map("sort_order")
  isWon     Boolean  @default(false) @map("is_won")
  isLost    Boolean  @default(false) @map("is_lost")
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@index([tenantId])
  @@map("pipeline_stages")
}

// Placeholder record for the Finance Agent n8n flow — a real accounting-tool
// integration (Xero/QuickBooks/Stripe) is a non-goal for v1 per PLAN.md;
// externalRef is where that tool's own invoice ID would go once wired up.
model Invoice {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  opportunityId String   @map("opportunity_id")
  amount        Decimal  @db.Decimal(12, 2)
  currency      String   @default("USD")
  status        String   @default("draft")
  externalRef   String?  @map("external_ref")
  createdAt     DateTime @default(now()) @map("created_at")

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([opportunityId])
  @@map("invoices")
}

// Generic IP-based rate limiter backing (login, signup, and other public
// endpoints) — a plain Postgres table rather than Redis, consistent with the
// "one less service to run" decision from PLAN.md's Phase 0 tech-stack pick.
model RateLimitHit {
  id        String   @id @default(cuid())
  key       String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([key, createdAt])
  @@map("rate_limit_hits")
}

// Records security-sensitive actions (auth events, API key/webhook endpoint
// changes) independently of the per-entity Activity timeline, which only
// tracks business-record changes (leads/opportunities/etc).
model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String?  @map("tenant_id")
  actorUserId String?  @map("actor_user_id")
  action      String
  metadata    Json?
  ipAddress   String?  @map("ip_address")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@map("audit_logs")
}
